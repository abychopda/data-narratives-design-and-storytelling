    <worksheet name='KPI - MH Score'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#1f3864' fontname='Benton Sans Book' fontsize='10'>                 Market Health Score</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_housing_affordability_dataset_imputed' name='federated.0fksw5k1j1adv319ck3id0f8r7xr' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='KPI Anchor Year' datatype='integer' datatype-customized='true' default-format='n0;-0' name='[Parameter 3]' param-domain-type='list' role='measure' type='quantitative' value='2026'>
              <calculation class='tableau' formula='2026' />
            </column>
            <column alias='Feb' caption='KPI Anchor Month' datatype='integer' name='[Parameter 4]' param-domain-type='list' role='measure' type='quantitative' value='2'>
              <calculation class='tableau' formula='2' />
              <aliases>
                <alias key='1' value='Jan' />
                <alias key='2' value='Feb' />
                <alias key='3' value='Mar' />
                <alias key='4' value='Apr' />
                <alias key='5' value='May' />
                <alias key='6' value='Jun' />
                <alias key='7' value='Jul' />
                <alias key='8' value='Aug' />
                <alias key='9' value='Sep' />
                <alias key='10' value='Oct' />
                <alias key='11' value='Nov' />
                <alias key='12' value='Dec' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0fksw5k1j1adv319ck3id0f8r7xr'>
            <column caption='KPI MHS vs Last Year' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_0126236309991436]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MIN(10, MAX(0, (AVG([Calculation_2815916946350083]) - 0.015) / (0.06 - 0.015) * 10))&#13;&#10;- MIN(10, MAX(0, (AVG([Calculation_2815916946472964]) - 0.015) / (0.06 - 0.015) * 10))' />
            </column>
            <column caption='KPI Market health score delta' datatype='string' name='[Calculation_0126236313358349]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0126236309991436] &gt; 0 THEN &quot;▲&quot; ELSEIF [Calculation_0126236309991436] &lt; 0 THEN &quot;▼&quot; ELSE &quot;—&quot; END' />
            </column>
            <column caption='Affordability Ratio' datatype='real' default-format='n#,##0.000;-#,##0.000' name='[Calculation_1820855438987269]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[median_household_income_lagged] / [home_value]' />
            </column>
            <column caption='Economic Stability' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1820855439044614]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1 - ([unemployment_rate] / 100)' />
            </column>
            <column caption='Investment Score' datatype='real' default-format='n#,##0.0000;-#,##0.0000' name='[Calculation_1820855439097863]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1820855438987269]&#13;&#10;* (1 / [mortgage_rate])&#13;&#10;* [Calculation_1820855439044614]' />
            </column>
            <column caption='LOD MHS Current' datatype='real' name='[Calculation_2815916946350083]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3]&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855439097863] END&#13;&#10;)}' />
            </column>
            <column caption='LOD MHS Prior' datatype='real' name='[Calculation_2815916946472964]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 1&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855439097863] END&#13;&#10;)}' />
            </column>
            <column caption='KPI Market Health Score 0-10' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_MHS010]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MIN(10, MAX(0, (AVG([Calculation_1820855439097863]) - 0.015) / (0.06 - 0.015) * 10))' />
            </column>
            <column caption='KPI Market Health Category' datatype='string' name='[Calculation_MHSCAT]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_MHS010] &gt;= 6 THEN &quot;High&quot; ELSEIF [Calculation_MHS010] &gt;= 3.5 THEN &quot;Moderate&quot; ELSE &quot;Low&quot; END' />
            </column>
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Home Value' datatype='real' name='[home_value]' role='measure' type='quantitative' />
            <column caption='Median Household Income Lagged' datatype='integer' name='[median_household_income_lagged]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='Month' name='[mn:date:ok]' pivot='key' type='ordinal' />
