      <column caption='Bar - Selected State' datatype='real' default-format='*$#,##0,K' name='[Calculation_0698807659749392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [state] = [Parameters].[Parameter 2] THEN [home_value] ELSE NULL END)' />
