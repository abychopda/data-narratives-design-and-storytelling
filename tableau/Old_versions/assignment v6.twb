      </column>
      <column caption='State Rank Direction' datatype='string' name='[Calculation_0698807656927247]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0698807656820749] &gt;= 0.045 THEN &quot; — Top Tier 🏆&quot;&#13;&#10;ELSEIF [Calculation_0698807656820749] &gt;= 0.030 THEN &quot; — Middle Tier&quot;&#13;&#10;ELSE &quot; — Needs Improvement&quot;&#13;&#10;END' />
