        <calculation class='tableau' formula='MIN(10, MAX(0, (0.40 - AVG([Calculation_2815916946526213])) / (0.40 - 0.10) * 10))&#13;&#10;- MIN(10, MAX(0, (0.40 - AVG([Calculation_2815916946567174])) / (0.40 - 0.10) * 10))' />
      </column>
      <column caption='KPI Affordability delta' datatype='string' name='[Calculation_0126236341825552]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0126236341452815] &gt; 0 THEN &quot;▲&quot; ELSEIF [Calculation_0126236341452815] &lt; 0 THEN &quot;▼&quot; ELSE &quot;—&quot; END' />
      </column>
      <column caption='KPI YoY Category' datatype='string' name='[Calculation_0126236343406609]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1219424275316736] &gt;= 0.03 THEN &quot;High Growth&quot;&#13;&#10;ELSEIF [Calculation_1219424275316736] &gt;= 0 THEN &quot;Moderate Growth&quot;&#13;&#10;ELSE &quot;Declining&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI YoY vs Last Year' datatype='real' name='[Calculation_0126236343676946]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Calculation_2815916946829323]) - AVG([Calculation_2815916946882572])) / ABS(AVG([Calculation_2815916946882572]))&#13;&#10;- (AVG([Calculation_2815916946882572]) - AVG([Calculation_2815916946923533])) / ABS(AVG([Calculation_2815916946923533]))' />
      </column>
      <column caption='KPI YoY Arrow' datatype='string' name='[Calculation_0126236343910419]' role='measure' type='nominal'>
