    <worksheet name='KPI - Mortgage Rate'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#1f3864' fontname='Benton Sans Book' fontsize='10'>Mortgage Rate</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_housing_affordability_dataset_imputed' name='federated.0fksw5k1j1adv319ck3id0f8r7xr' />
          </datasources>
          <datasource-dependencies datasource='federated.0fksw5k1j1adv319ck3id0f8r7xr'>
            <column caption=' KPI Mortgage vs Last Year' datatype='real' name='[Calculation_0126236346150932]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG(IF YEAR([date])=2026 AND MONTH([date])=2 THEN [mortgage_rate] END)&#13;&#10;-&#13;&#10;AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [mortgage_rate] END)' />
            </column>
            <column caption='KPI Mortgage Arrow' datatype='string' name='[Calculation_0126236346789909]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG(IF YEAR([date])=2026 AND MONTH([date])=2 THEN [mortgage_rate] END)&#13;&#10;&gt;= AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [mortgage_rate] END)&#13;&#10;THEN &quot;▲&quot; ELSE &quot;▼&quot;&#13;&#10;END' />
            </column>
            <column caption='Monthly Income' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438614528]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[median_household_income_lagged] / 12' />
            </column>
            <column caption='Loan Amount' datatype='real' name='[Calculation_1820855438696449]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[home_value] * 0.8' />
            </column>
            <column caption='Monthly Rate' datatype='real' name='[Calculation_1820855438766082]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([mortgage_rate] / 100) / 12' />
            </column>
            <column caption='Monthly Mortgage Payment' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438835715]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1820855438696449]&#13;&#10;* ([Calculation_1820855438766082] * (1 + [Calculation_1820855438766082])^360)&#13;&#10;/ ((1 + [Calculation_1820855438766082])^360 - 1)' />
            </column>
            <column caption='Mortgage Burden Ratio' datatype='real' default-format='p0.0%' name='[Calculation_1820855438934020]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1820855438835715] / [Calculation_1820855438614528]' />
            </column>
            <column caption='Affordability Ratio' datatype='real' default-format='n#,##0.000;-#,##0.000' name='[Calculation_1820855438987269]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[median_household_income_lagged] / [home_value]' />
            </column>
            <column caption='Economic Stability' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1820855439044614]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1 - ([unemployment_rate] / 100)' />
            </column>
            <column caption='Investment Score' datatype='real' default-format='n#,##0.0000;-#,##0.0000' name='[Calculation_1820855439097863]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1820855438987269]&#13;&#10;* (1 / [mortgage_rate])&#13;&#10;* [Calculation_1820855439044614]' />
            </column>
            <column caption='Affordability Category' datatype='string' name='[Calculation_1820855439241225]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1820855438934020] &gt;= 0.40 THEN &quot;Crisis (&gt;40%)&quot;&#13;&#10;ELSEIF [Calculation_1820855438934020] &gt;= 0.30 THEN &quot;Cost-Burdened (30-40%)&quot;&#13;&#10;ELSEIF [Calculation_1820855438934020] &gt;= 0.20 THEN &quot;Stretched (20-30%)&quot;&#13;&#10;ELSE &quot;Affordable (&lt;20%)&quot;&#13;&#10;END' />
            </column>
            <column caption='Investment Category' datatype='string' name='[Calculation_1820855439319050]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1820855439097863] &gt;= 0.045 THEN &quot;High Opportunity&quot;&#13;&#10;ELSEIF [Calculation_1820855439097863] &gt;= 0.030 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;Low Opportunity&quot;&#13;&#10;END' />
            </column>
            <column caption='KPI Mortgage Category' datatype='string' name='[Calculation_MORTCAT]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([mortgage_rate]) &lt;= 5 THEN &quot;Healthy&quot;&#13;&#10;ELSEIF AVG([mortgage_rate]) &lt;= 7 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;Stressed&quot;&#13;&#10;END' />
            </column>
            <column-instance column='[mortgage_rate]' derivation='Avg' name='[avg:mortgage_rate:qk]' pivot='key' type='quantitative' />
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Home Value' datatype='real' name='[home_value]' role='measure' type='quantitative' />
            <column caption='Median Household Income Lagged' datatype='integer' name='[median_household_income_lagged]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='Month' name='[mn:date:ok]' pivot='key' type='ordinal' />
            <column caption='Mortgage Rate' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[mortgage_rate]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='None' name='[none:date:qk]' pivot='key' type='quantitative' />
