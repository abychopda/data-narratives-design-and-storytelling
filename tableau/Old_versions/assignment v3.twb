      <simple-id uuid='{80C61E70-C745-4100-B0E9-0BDAE9D4651A}' />
    </dashboard>
    <dashboard name='Part 2 Pitch' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>US Housing Affordability Crisis 2024–2026</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='900' maxwidth='1600' minheight='900' minwidth='1600' preset-index='8' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98222' id='7' param='vert' removable='false' type-v2='layout-flow' w='99000' x='500' y='889'>
            <zone h='4111' id='8' type-v2='title' w='99000' x='500' y='889'>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='4' />
              </zone-style>
            </zone>
            <zone h='94111' id='1' param='vert' removable='false' type-v2='layout-flow' w='99000' x='500' y='5000'>
              <zone h='8778' id='4' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99000' x='500' y='5000' />
              <zone h='85333' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99000' x='500' y='13778'>
                <flipboard active-id='5' nav-type='number' show-nav-arrows='true'>
                  <story-points>
                    <story-point captured-sheet='Overview' id='1' />
                    <story-point captured-sheet='Trend - Home Price vs Mortgage Rate' id='2' />
                    <story-point captured-sheet='Scatter - Affordability vs Unemployment' id='3' />
                    <story-point captured-sheet='Mortgage Burden by State' id='4' />
                    <story-point captured-sheet='What-If Payment Calculator' id='5' />
                    <story-point captured-sheet='Overview' id='6' />
                  </story-points>
                </flipboard>
              </zone>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3333' hidden='true' id='9' story-point-id='1' type-v2='text' w='60938' x='18375' y='11000'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>THE CRISIS: 16 states require more than 30% of income for mortgage alone. Hawaii demands 47.9%.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3222' hidden='true' id='10' story-point-id='2' type-v2='text' w='65438' x='13188' y='10889'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>THE VILLAIN: Rates hit 7.06% in May 2024. Home prices kept rising. The market decoupled from affordability.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3111' hidden='true' id='11' story-point-id='3' type-v2='text' w='73500' x='8063' y='11667'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>THE PARADOX: r=0.07. Unemployment barely explains home prices. Hawaii has 2.5% unemployment and the worst score.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3000' hidden='true' id='12' story-point-id='4' type-v2='text' w='57688' x='18375' y='10778'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>THE EVIDENCE: Hawaii 47.9%, California 44.9%. Only 8 states are genuinely affordable.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3111' id='13' story-point-id='5' type-v2='text' w='77688' x='8188' y='11000'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>THE RELIEF: Move the slider to 4.5%. California saves $828/month. But Hawaii stays in crisis — rate cuts alone aren&apos;t enough.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='3111' hidden='true' id='14' story-point-id='6' type-v2='text' w='86813' x='4625' y='10778'>
          <formatted-text>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontname='Benton Sans Book'>THE ASK: Three policy actions: rate reduction below 6%, fast-track rezoning, adopt the Market Health Score as federal policy index. Explore any state.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{2309E3DE-B052-448B-8BF7-BE69C406A58F}' />
    </dashboard>
