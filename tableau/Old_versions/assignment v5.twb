          <datasource-dependencies datasource='federated.0fksw5k1j1adv319ck3id0f8r7xr'>
            <column caption='KPI YoY Category' datatype='string' name='[Calculation_0126236343406609]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1219424275316736] &gt;= 0.03 THEN &quot;High Growth&quot;&#13;&#10;ELSEIF [Calculation_1219424275316736] &gt;= 0 THEN &quot;Moderate Growth&quot;&#13;&#10;ELSE &quot;Declining&quot;&#13;&#10;END' />
            </column>
            <column caption='KPI YoY vs Last Year' datatype='real' name='[Calculation_0126236343676946]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(AVG([Calculation_2815916946829323]) - AVG([Calculation_2815916946882572])) / ABS(AVG([Calculation_2815916946882572]))&#13;&#10;- (AVG([Calculation_2815916946882572]) - AVG([Calculation_2815916946923533])) / ABS(AVG([Calculation_2815916946923533]))' />
            </column>
            <column caption='KPI YoY Arrow' datatype='string' name='[Calculation_0126236343910419]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0126236343676946] &gt; 0 THEN &quot;▲&quot; ELSEIF [Calculation_0126236343676946] &lt; 0 THEN &quot;▼&quot; ELSE &quot;—&quot; END' />
            </column>
            <column caption='KPI YoY Value' datatype='real' default-format='p0.00%' name='[Calculation_1219424275316736]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(AVG([Calculation_2815916946829323]) - AVG([Calculation_2815916946882572]))&#13;&#10;/ ABS(AVG([Calculation_2815916946882572]))' />
            </column>
            <column caption='LOD HV Current' datatype='real' name='[Calculation_2815916946829323]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(IF YEAR([date]) = YEAR({MAX([date])}) AND MONTH([date]) = MONTH({MAX([date])}) THEN [home_value] END) }' />
            </column>
            <column caption='LOD HV Prior' datatype='real' name='[Calculation_2815916946882572]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(IF YEAR([date]) = YEAR({MAX([date])}) - 1 AND MONTH([date]) = MONTH({MAX([date])}) THEN [home_value] END) }' />
            </column>
            <column caption='LOD HV Two Years Ago' datatype='real' name='[Calculation_2815916946923533]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(IF YEAR([date]) = YEAR({MAX([date])}) - 2 AND MONTH([date]) = MONTH({MAX([date])}) THEN [home_value] END) }' />
            </column>
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Home Value' datatype='real' name='[home_value]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='Month' name='[mn:date:ok]' pivot='key' type='ordinal' />
            <column-instance column='[date]' derivation='None' name='[none:date:qk]' pivot='key' type='quantitative' />
