            <column-instance column='[Calculation_MORTCAT]' derivation='User' name='[usr:Calculation_MORTCAT:nk]' pivot='key' type='nominal' />
            <column-instance column='[date]' derivation='Year' name='[yr:date:ok]' pivot='key' type='ordinal' />
