        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN &quot;Selected&quot; ELSE &quot;Other&quot; END' />
      </column>
      <column caption='State Rank Row Colour' datatype='string' name='[Calculation_0698807677292572]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN &quot;Show&quot; ELSE &quot;Hide&quot; END' />
      </column>
      <column caption='State Rank Sort' datatype='integer' name='[Calculation_0698807692714014]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [state] = [Parameters].[Parameter 2] THEN 0 ELSE 1 END' />
