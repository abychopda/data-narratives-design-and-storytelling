    <worksheet name='SV - Rate Sensitivity Table'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#1f3864' fontname='Benton Sans Book' fontsize='11'>Monthly Payment Sensitivity </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#818b91' fontname='Benton Sans Book' fontsize='8'>(30-yr Fixed, 20% Down)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_housing_affordability_dataset_imputed' name='federated.0fksw5k1j1adv319ck3id0f8r7xr' />
          </datasources>
          <datasource-dependencies datasource='federated.0fksw5k1j1adv319ck3id0f8r7xr'>
            <column caption='Rate Row 4.0%' datatype='string' name='[Calculation_0698807662190610]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;4.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;4.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;4.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
            </column>
            <column caption='Rate Row 4.5%' datatype='string' name='[Calculation_0698807668019220]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;4.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;4.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;4.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
            </column>
            <column caption='Rate Row 5.0%' datatype='string' name='[Calculation_0698807668056085]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;5.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005368))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;5.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005368))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;5.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005368))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
            </column>
            <column caption='Rate Row 5.5%' datatype='string' name='[Calculation_0698807668092950]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;5.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005679))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;5.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005679))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;5.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005679))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
            </column>
            <column caption='Rate Row 6.0%' datatype='string' name='[Calculation_0698807668154391]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;6.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005996))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;6.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005996))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;6.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005996))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
            </column>
            <column caption='Rate Row 6.5%' datatype='string' name='[Calculation_0698807668187160]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;6.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.006320))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;6.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.006320))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;6.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.006320))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
