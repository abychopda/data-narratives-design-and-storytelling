      <column caption='Bar - National Average' datatype='real' default-format='*$#,##0,K' name='[Calculation_0698807659794449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value])' />
      </column>
      <column caption='Rate Row 4.0%' datatype='string' name='[Calculation_0698807662190610]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;4.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;4.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;4.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='State Rank Label' datatype='string' name='[Calculation_0698807663157267]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2]&#13;&#10;THEN &quot;#&quot; + STR(RANK_UNIQUE(AVG([Calculation_1820855439097863]), &apos;desc&apos;)) + &quot; of 51 states&quot;&#13;&#10;ELSE &quot;&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rate Row 4.5%' datatype='string' name='[Calculation_0698807668019220]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;4.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;4.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;4.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
