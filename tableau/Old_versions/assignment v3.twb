                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='8' italic='true'>- Zillow ZHVI (Home Values), </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='8' italic='true'>- FRED MORTGAGE30US (Mortgage Rates), </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='8' italic='true'>- BLS LAUS (Employment), </run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book' fontsize='8' italic='true'>- US Census ACS 2023/2024 (Income); </run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book' italic='true'>Period: January 2024 - February 2026</run>
                  </formatted-text>
