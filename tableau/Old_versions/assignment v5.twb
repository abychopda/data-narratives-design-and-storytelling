    <worksheet name='KPI - Affordability Score'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#1f3864' fontname='Benton Sans Book' fontsize='10'>                 House Affordability Score</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_housing_affordability_dataset_imputed' name='federated.0fksw5k1j1adv319ck3id0f8r7xr' />
          </datasources>
          <datasource-dependencies datasource='federated.0fksw5k1j1adv319ck3id0f8r7xr'>
            <column caption='KPI Housing Affordability Score 0-10' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_0126236340625422]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MIN(10, MAX(0, (0.40 - AVG([Calculation_1820855438934020])) / (0.40 - 0.10) * 10))' />
            </column>
            <column caption='KPI Affordability vs Last Year' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_0126236341452815]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MIN(10, MAX(0, (0.40 - AVG([Calculation_2815916946526213])) / (0.40 - 0.10) * 10))&#13;&#10;- MIN(10, MAX(0, (0.40 - AVG([Calculation_2815916946567174])) / (0.40 - 0.10) * 10))' />
            </column>
            <column caption='KPI Affordability delta' datatype='string' name='[Calculation_0126236341825552]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0126236341452815] &gt; 0 THEN &quot;▲&quot; ELSEIF [Calculation_0126236341452815] &lt; 0 THEN &quot;▼&quot; ELSE &quot;—&quot; END' />
            </column>
            <column caption='Monthly Income' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438614528]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[median_household_income_lagged] / 12' />
            </column>
            <column caption='Loan Amount' datatype='real' name='[Calculation_1820855438696449]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[home_value] * 0.8' />
            </column>
            <column caption='Monthly Rate' datatype='real' name='[Calculation_1820855438766082]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([mortgage_rate] / 100) / 12' />
            </column>
            <column caption='Monthly Mortgage Payment' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438835715]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1820855438696449]&#13;&#10;* ([Calculation_1820855438766082] * (1 + [Calculation_1820855438766082])^360)&#13;&#10;/ ((1 + [Calculation_1820855438766082])^360 - 1)' />
            </column>
            <column caption='Mortgage Burden Ratio' datatype='real' default-format='p0.0%' name='[Calculation_1820855438934020]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1820855438835715] / [Calculation_1820855438614528]' />
            </column>
            <column caption='LOD Afford Current' datatype='real' name='[Calculation_2815916946526213]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(IF YEAR([date]) = YEAR({MAX([date])}) AND MONTH([date]) = MONTH({MAX([date])}) THEN [Calculation_1820855438934020] END) }' />
            </column>
            <column caption='LOD Afford Prior' datatype='real' name='[Calculation_2815916946567174]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [state] : AVG(IF YEAR([date]) = YEAR({MAX([date])}) - 1 AND MONTH([date]) = MONTH({MAX([date])}) THEN [Calculation_1820855438934020] END) }' />
            </column>
            <column caption='KPI Affordability Category' datatype='string' name='[Calculation_AFFCAT]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF MIN(10,MAX(0,(0.40-AVG([Calculation_1820855438934020]))/(0.40-0.10)*10)) &gt;= 6 THEN &quot;Healthy&quot; ELSEIF MIN(10,MAX(0,(0.40-AVG([Calculation_1820855438934020]))/(0.40-0.10)*10)) &gt;= 3.5 THEN &quot;Moderate&quot; ELSE &quot;Stressed&quot; END' />
            </column>
            <column caption='Date' datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column caption='Home Value' datatype='real' name='[home_value]' role='measure' type='quantitative' />
            <column caption='Median Household Income Lagged' datatype='integer' name='[median_household_income_lagged]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='Month' name='[mn:date:ok]' pivot='key' type='ordinal' />
            <column caption='Mortgage Rate' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[mortgage_rate]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='None' name='[none:date:qk]' pivot='key' type='quantitative' />
