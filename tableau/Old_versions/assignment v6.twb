            <column-instance column='[Calculation_1181150743982083]' derivation='Sum' name='[sum:Calculation_1181150743982083:qk]' pivot='key' type='quantitative' />
            <column caption='Unemployment Rate' datatype='real' default-format='*0.00\%' name='[unemployment_rate]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2442356451745793]' derivation='User' name='[usr:Calculation_2442356451745793:nk]' pivot='key' type='nominal' />
            <column-instance column='[date]' derivation='Year' name='[yr:date:ok]' pivot='key' type='ordinal' />
