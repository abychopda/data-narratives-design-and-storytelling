      </column>
      <column caption='State Insight' datatype='string' name='[Calculation_0895342940409857]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1820855438934020]) &gt;= 0.40 THEN&#13;&#10;  &quot;This state is in housing crisis. Over 40% of income goes to mortgage alone. Immediate supply-side intervention needed.&quot;&#13;&#10;ELSEIF AVG([Calculation_1820855438934020]) &gt;= 0.30 THEN&#13;&#10;  &quot;This state is cost-burdened. Residents spend 30-40% of income on housing. Zoning reform and affordable housing investment recommended.&quot;&#13;&#10;ELSEIF AVG([Calculation_1820855439097863]) &gt;= 0.045 THEN&#13;&#10;  &quot;This state shows a healthy housing market with manageable affordability. Strong opportunity for sustainable development.&quot;&#13;&#10;ELSE&#13;&#10;  &quot;This state shows moderate housing stress. Monitor affordability trends and consider targeted subsidy programmes.&quot;&#13;&#10;END' />
      </column>
      <column caption='State Insight Filter' datatype='boolean' name='[Calculation_0897269889589248]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[state] = [Parameters].[Parameter 2] OR [Parameters].[Parameter 2] = &quot;All States&quot;' />
      </column>
      <column caption='Reset Button' datatype='string' name='[Calculation_0897269910396929]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;↺  Reset to All States&quot;' />
      </column>
      <column caption='LOD Max Year' datatype='integer' name='[Calculation_1181150737600512]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : YEAR(MAX([date])) }' />
      </column>
      <column caption='LOD Max Month' datatype='integer' name='[Calculation_1181150737653761]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED : MONTH(MAX([date])) }' />
      </column>
      <column caption='Date Year' datatype='integer' name='[Calculation_1181150743932930]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([date])' />
      </column>
      <column caption='Date Month' datatype='integer' name='[Calculation_1181150743982083]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([date])' />
      </column>
      <column caption='KPI YoY Value' datatype='real' default-format='p0.00%' name='[Calculation_1219424275316736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Calculation_2815916946829323]) - AVG([Calculation_2815916946882572]))&#13;&#10;/ ABS(AVG([Calculation_2815916946882572]))' />
      </column>
      <column caption='Home Value Comparison Label' datatype='string' name='[Calculation_1585288625455106]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;$&quot; + STR(INT(AVG([home_value]) / 1000)) + &quot;K&quot;' />
      </column>
      <column caption='Monthly Income' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438614528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[median_household_income_lagged] / 12' />
      </column>
      <column caption='Loan Amount' datatype='real' name='[Calculation_1820855438696449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[home_value] * 0.8' />
      </column>
      <column caption='Monthly Rate' datatype='real' name='[Calculation_1820855438766082]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([mortgage_rate] / 100) / 12' />
      </column>
      <column caption='Monthly Mortgage Payment' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438835715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438696449]&#13;&#10;* ([Calculation_1820855438766082] * (1 + [Calculation_1820855438766082])^360)&#13;&#10;/ ((1 + [Calculation_1820855438766082])^360 - 1)' />
      </column>
      <column caption='Mortgage Burden Ratio' datatype='real' default-format='p0.0%' name='[Calculation_1820855438934020]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438835715] / [Calculation_1820855438614528]' />
      </column>
      <column caption='Affordability Ratio' datatype='real' default-format='n#,##0.000;-#,##0.000' name='[Calculation_1820855438987269]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[median_household_income_lagged] / [home_value]' />
      </column>
      <column caption='Economic Stability' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1820855439044614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - ([unemployment_rate] / 100)' />
      </column>
      <column caption='Investment Score' datatype='real' default-format='n#,##0.0000;-#,##0.0000' name='[Calculation_1820855439097863]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438987269]&#13;&#10;* (1 / [mortgage_rate])&#13;&#10;* [Calculation_1820855439044614]' />
      </column>
      <column caption='YoY Home Value Change' datatype='real' name='[Calculation_1820855439142920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([home_value])) - LOOKUP(ZN(SUM([home_value])), -12)) / ABS(LOOKUP(ZN(SUM([home_value])), -12))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Affordability Category' datatype='string' name='[Calculation_1820855439241225]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1820855438934020] &gt;= 0.40 THEN &quot;Crisis (&gt;40%)&quot;&#13;&#10;ELSEIF [Calculation_1820855438934020] &gt;= 0.30 THEN &quot;Cost-Burdened (30-40%)&quot;&#13;&#10;ELSEIF [Calculation_1820855438934020] &gt;= 0.20 THEN &quot;Stretched (20-30%)&quot;&#13;&#10;ELSE &quot;Affordable (&lt;20%)&quot;&#13;&#10;END' />
      </column>
      <column caption='Investment Category' datatype='string' name='[Calculation_1820855439319050]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1820855439097863] &gt;= 0.045 THEN &quot;High Opportunity&quot;&#13;&#10;ELSEIF [Calculation_1820855439097863] &gt;= 0.030 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;Low Opportunity&quot;&#13;&#10;END' />
      </column>
      <column caption='Home Value ($K)' datatype='real' default-format='*$#,##0.0&quot;K&quot;' name='[Calculation_1820855439364107]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[home_value] / 1000' />
      </column>
      <column caption='What-If Monthly Payment' datatype='real' name='[Calculation_1820855439699980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([home_value] * 0.8)&#13;&#10;* (([Parameters].[Parameter 1]/100/12) * (1+([Parameters].[Parameter 1]/100/12))^360)&#13;&#10;/ ((1+([Parameters].[Parameter 1]/100/12))^360 - 1)' />
      </column>
      <column caption='What-If Mortgage Burden' datatype='real' name='[Calculation_1820855439757325]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855439699980] / [Calculation_1820855438614528]' />
      </column>
      <column caption='Monthly Savings from Rate Cut' datatype='real' default-format='*$#,##0' name='[Calculation_1820855439818766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438835715] - [Calculation_1820855439699980]' />
      </column>
      <column caption='YoY Category' datatype='string' name='[Calculation_1820855471538191]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1820855439142920] &gt;= 0 THEN &quot;Growing&quot;&#13;&#10;ELSE &quot;Falling&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='What-If Savings Label' datatype='string' name='[Calculation_2143291561586689]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1820855439818766]) &gt;= 0&#13;&#10;THEN &quot;Save $&quot; + STR(INT(AVG([Calculation_1820855439818766])))&#13;&#10;ELSE &quot;Cost +&quot; + STR(INT(ABS(AVG([Calculation_1820855439818766])))) + &quot; extra&quot;&#13;&#10;END' />
      </column>
      <column caption='What-If Bar Color' datatype='string' name='[Calculation_2143291561668610]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1820855439818766]) &gt;= 0&#13;&#10;THEN &quot;Savings&quot;&#13;&#10;ELSE &quot;Cost Increase&quot;&#13;&#10;END' />
      </column>
      <column caption='Key Insight' datatype='string' name='[Calculation_2442356450684928]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN&#13;&#10;  IF AVG([Calculation_1820855438934020]) &gt;= 0.40 THEN&#13;&#10;    [Parameters].[Parameter 2] + &quot; is in HOUSING CRISIS. &quot; +&#13;&#10;    &quot;Monthly mortgage consumes &quot; + &#13;&#10;    STR(ROUND(AVG([Calculation_1820855438934020])*100,1)) + &#13;&#10;    &quot;% of median income — above the 40% HUD severe threshold.&quot;&#13;&#10;  ELSEIF AVG([Calculation_1820855438934020]) &gt;= 0.30 THEN&#13;&#10;    [Parameters].[Parameter 2] + &quot; is COST-BURDENED. &quot; +&#13;&#10;    STR(ROUND(AVG([Calculation_1820855438934020])*100,1)) +&#13;&#10;    &quot;% of income consumed by mortgage — above HUD&apos;s 30% threshold.&quot;&#13;&#10;  ELSEIF MIN(10, MAX(0, (AVG([Calculation_1820855439097863]) - 0.015) / (0.06 - 0.015) * 10)) &gt;= 6 THEN&#13;&#10;  [Parameters].[Parameter 2] + &quot; has a HEALTHY housing market. &quot; +&#13;&#10;  &quot;Market Health Score: &quot; + STR(ROUND([Calculation_MHS010], 1)) +&#13;&#10;  &quot;/10 — affordable relative to income with stable employment.&quot;&#13;&#10;  ELSE&#13;&#10;    [Parameters].[Parameter 2] + &quot; shows MODERATE stress. &quot; +&#13;&#10;    &quot;Monitor affordability trends. Income-price ratio: &quot; +&#13;&#10;    STR(ROUND(AVG([Calculation_1820855438987269]),3))&#13;&#10;  END&#13;&#10;ELSE&#13;&#10;  &quot;Select a state on the map to see its insight.&quot;&#13;&#10;END' />
      </column>
      <column caption='Recommended Policy Actions' datatype='string' name='[Calculation_2442356451745793]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN&#13;&#10;  IF AVG([Calculation_1820855438934020]) &gt;= 0.40 THEN&#13;&#10;    &quot;1. Emergency affordable housing investment&quot; + CHAR(10) +&#13;&#10;    &quot;2. Fast-track social housing zoning&quot; + CHAR(10) +&#13;&#10;    &quot;3. Lobby for federal rate intervention below 6%&quot; + CHAR(10) +&#13;&#10;    &quot;4. First-home buyer subsidy programme&quot;&#13;&#10;  ELSEIF AVG([Calculation_1820855438934020]) &gt;= 0.30 THEN&#13;&#10;    &quot;1. Zoning reform — increase housing supply&quot; + CHAR(10) +&#13;&#10;    &quot;2. Incentivise affordable unit development&quot; + CHAR(10) +&#13;&#10;    &quot;3. Monitor rent-to-own conversion rates&quot; + CHAR(10) +&#13;&#10;    &quot;4. Anti-speculation land tax review&quot;&#13;&#10;  ELSEIF MIN(10, MAX(0, (AVG([Calculation_1820855439097863]) - 0.015) / (0.06 - 0.015) * 10)) &gt;= 6 THEN&#13;&#10;    &quot;1. Invest in infrastructure to support growth&quot; + CHAR(10) +&#13;&#10;    &quot;2. Maintain current zoning flexibility&quot; + CHAR(10) +&#13;&#10;    &quot;3. Attract workforce housing development&quot; + CHAR(10) +&#13;&#10;    &quot;4. Monitor for investor demand pressure&quot;&#13;&#10;  ELSE&#13;&#10;    &quot;1. Conduct affordability impact assessment&quot; + CHAR(10) +&#13;&#10;    &quot;2. Review housing supply pipeline&quot; + CHAR(10) +&#13;&#10;    &quot;3. Consider targeted rental subsidy&quot; + CHAR(10) +&#13;&#10;    &quot;4. Track YoY price growth quarterly&quot;&#13;&#10;  END&#13;&#10;ELSE&#13;&#10;  &quot;Select a state on the map for policy recommendations.&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI YoY by State' datatype='real' default-format='p0.00%' name='[Calculation_2442356452065282]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END) = 0&#13;&#10;OR ISNULL(AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END))&#13;&#10;THEN NULL&#13;&#10;ELSE&#13;&#10;  (AVG(IF YEAR([date])=2026 AND MONTH([date])=2 THEN [home_value] END) -&#13;&#10;   AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END)) /&#13;&#10;  ABS(AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END))&#13;&#10;END' />
      </column>
      <column caption='Burden Filter Combined' datatype='boolean' name='[Calculation_2442356459171843]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Top 20 Burden States] OR ([state] = [Parameters].[Parameter 2])' />
      </column>
      <column caption='Selected State Match' datatype='boolean' name='[Calculation_2442356460617732]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[state] = [Parameters].[Parameter 2]' />
      </column>
      <column caption='What if Filter Combined' datatype='boolean' name='[Calculation_2442356463087621]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Top 15 Payment States] OR ([state] = [Parameters].[Parameter 2])' />
      </column>
      <column caption='Selected Year Max' datatype='integer' name='[Calculation_2815916926222337]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR({MAX([date])})' />
      </column>
      <column caption='Selected Month Max' datatype='integer' name='[Calculation_2815916926296066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH({MAX([date])})' />
      </column>
      <column caption='LOD MHS Current' datatype='real' name='[Calculation_2815916946350083]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3]&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855439097863] END&#13;&#10;)}' />
      </column>
      <column caption='LOD MHS Prior' datatype='real' name='[Calculation_2815916946472964]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 1&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855439097863] END&#13;&#10;)}' />
      </column>
      <column caption='LOD Afford Current' datatype='real' name='[Calculation_2815916946526213]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3]&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855438934020] END&#13;&#10;)}' />
      </column>
      <column caption='LOD Afford Prior' datatype='real' name='[Calculation_2815916946567174]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 1&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855438934020] END&#13;&#10;)}' />
      </column>
      <column caption='LOD Mortgage Current' datatype='real' name='[Calculation_2815916946608135]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3]&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [mortgage_rate] END&#13;&#10;)}' />
      </column>
      <column caption='LOD Mortgage Prior' datatype='real' name='[Calculation_2815916946665480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 1&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [mortgage_rate] END&#13;&#10;)}' />
      </column>
      <column caption='LOD Econ Current' datatype='real' name='[Calculation_2815916946714633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3]&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855439044614] END&#13;&#10;)}' />
      </column>
      <column caption='LOD Econ Prior' datatype='real' name='[Calculation_2815916946767882]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 1&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [Calculation_1820855439044614] END&#13;&#10;)}' />
      </column>
      <column caption='LOD HV Current' datatype='real' name='[Calculation_2815916946829323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3]&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [home_value] END&#13;&#10;)}' />
      </column>
      <column caption='LOD HV Prior' datatype='real' name='[Calculation_2815916946882572]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 1&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [home_value] END&#13;&#10;)}' />
      </column>
      <column caption='LOD HV Two Years Ago' datatype='real' name='[Calculation_2815916946923533]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG(&#13;&#10;  IF YEAR([date]) = [Parameters].[Parameter 3] - 2&#13;&#10;  AND MONTH([date]) = [Parameters].[Parameter 4]&#13;&#10;  THEN [home_value] END&#13;&#10;)}' />
      </column>
      <column caption='KPI Affordability Category' datatype='string' name='[Calculation_AFFCAT]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF MIN(10,MAX(0,(0.40-AVG([Calculation_1820855438934020]))/(0.40-0.10)*10)) &gt;= 6 THEN &quot;Healthy&quot; ELSEIF MIN(10,MAX(0,(0.40-AVG([Calculation_1820855438934020]))/(0.40-0.10)*10)) &gt;= 3.5 THEN &quot;Moderate&quot; ELSE &quot;Stressed&quot; END' />
      </column>
      <column caption='KPI Econ Category' datatype='string' name='[Calculation_ECONCAT]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1820855439044614]) &gt;= 0.97 THEN &quot;High&quot; ELSEIF AVG([Calculation_1820855439044614]) &gt;= 0.95 THEN &quot;Moderate&quot; ELSE &quot;Low&quot; END' />
      </column>
      <column caption='KPI Market Health Score 0-10' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_MHS010]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN(10, MAX(0, (AVG([Calculation_1820855439097863]) - 0.015) / (0.06 - 0.015) * 10))' />
      </column>
      <column caption='KPI Market Health Category' datatype='string' name='[Calculation_MHSCAT]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_MHS010] &gt;= 6 THEN &quot;High&quot; ELSEIF [Calculation_MHS010] &gt;= 3.5 THEN &quot;Moderate&quot; ELSE &quot;Low&quot; END' />
      </column>
      <column caption='KPI Mortgage Category' datatype='string' name='[Calculation_MORTCAT]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([mortgage_rate]) &lt;= 5.5 THEN &quot;Low&quot; ELSEIF AVG([mortgage_rate]) &lt;= 7.0 THEN &quot;Moderate&quot; ELSE &quot;High&quot; END' />
      </column>
