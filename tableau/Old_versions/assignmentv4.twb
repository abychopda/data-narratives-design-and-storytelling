      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0fksw5k1j1adv319ck3id0f8r7xr].[avg:Calculation_1820855439097863:qk]&quot;' value='Score' />
