        <calculation class='tableau' formula='AVG([Calculation_2815916946608135]) - AVG([Calculation_2815916946665480])' />
      </column>
      <column caption='KPI Mortgage Arrow' datatype='string' name='[Calculation_0126236346789909]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0126236346150932] &gt; 0 THEN &quot;▲&quot; ELSEIF [Calculation_0126236346150932] &lt; 0 THEN &quot;▼&quot; ELSE &quot;—&quot; END' />
      </column>
      <column caption='KPI Econ vs Last Year' datatype='real' name='[Calculation_0126236349734934]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Calculation_2815916946714633]) - AVG([Calculation_2815916946767882])) * 100' />
      </column>
      <column caption='KPI Econ Arrow' datatype='string' name='[Calculation_0126236350746647]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0126236349734934] &gt; 0 THEN &quot;▲&quot; ELSEIF [Calculation_0126236349734934] &lt; 0 THEN &quot;▼&quot; ELSE &quot;—&quot; END' />
      </column>
      <column caption='TC - Show Latest Month Only' datatype='boolean' name='[Calculation_0461860084342794]' role='measure' type='nominal'>
        <calculation class='tableau' formula='INDEX() = WINDOW_MAX(INDEX())'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rate Sensitivity 4.0%' datatype='real' name='[Calculation_0698807653105664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value]) * 0.8 * &#13;&#10;(0.04/12 * POWER(1 + 0.04/12, 360)) / &#13;&#10;(POWER(1 + 0.04/12, 360) - 1)' />
      </column>
      <column caption='Rate Sensitivity 4.5%' datatype='real' name='[Calculation_0698807653171201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value]) * 0.8 * &#13;&#10;(0.045/12 * POWER(1 + 0.045/12, 360)) / &#13;&#10;(POWER(1 + 0.045/12, 360) - 1)' />
      </column>
      <column caption='Rate Sensitivity 5.0%' datatype='real' name='[Calculation_0698807653212162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value]) * 0.8 * &#13;&#10;(0.05/12 * POWER(1 + 0.05/12, 360)) / &#13;&#10;(POWER(1 + 0.05/12, 360) - 1)' />
      </column>
      <column caption='Rate Sensitivity 5.5%' datatype='real' name='[Calculation_0698807653253123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value]) * 0.8 * &#13;&#10;(0.055/12 * POWER(1 + 0.055/12, 360)) / &#13;&#10;(POWER(1 + 0.055/12, 360) - 1)' />
      </column>
      <column caption='Rate Sensitivity 6.0%' datatype='real' name='[Calculation_0698807653298180]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value]) * 0.8 * &#13;&#10;(0.06/12 * POWER(1 + 0.06/12, 360)) / &#13;&#10;(POWER(1 + 0.06/12, 360) - 1)' />
      </column>
      <column caption='Rate Sensitivity 6.5%' datatype='real' name='[Calculation_0698807653343237]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value]) * 0.8 * &#13;&#10;(0.065/12 * POWER(1 + 0.065/12, 360)) / &#13;&#10;(POWER(1 + 0.065/12, 360) - 1)' />
      </column>
      <column caption='Rate Sensitivity Burden 4.0%' datatype='real' name='[Calculation_0698807653494790]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0698807653105664] / AVG([Calculation_1820855438614528])' />
      </column>
      <column caption='Rate Sensitivity Burden 4.5%' datatype='real' name='[Calculation_0698807653556231]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0698807653171201] / AVG([Calculation_1820855438614528])' />
      </column>
      <column caption='Rate Sensitivity Burden 5.0%' datatype='real' name='[Calculation_0698807653646344]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0698807653212162] / AVG([Calculation_1820855438614528])' />
      </column>
      <column caption='Rate Sensitivity Burden 5.5%' datatype='real' name='[Calculation_0698807653691401]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0698807653253123] / AVG([Calculation_1820855438614528])' />
      </column>
      <column caption='Rate Sensitivity Burden 6.0%' datatype='real' name='[Calculation_0698807653830666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0698807653298180] / AVG([Calculation_1820855438614528])' />
      </column>
      <column caption='Rate Sensitivity Burden 6.5%' datatype='real' name='[Calculation_0698807653904395]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0698807653343237] / AVG([Calculation_1820855438614528])' />
      </column>
      <column caption='Burden Color Flag' datatype='string' name='[Calculation_0698807654973452]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0698807653105664] / AVG([Calculation_1820855438614528]) &gt;= 0.40 THEN &quot;Crisis&quot;&#13;&#10;  ELSEIF [Calculation_0698807653105664] / AVG([Calculation_1820855438614528]) &gt;= 0.30 THEN &quot;Burdened&quot;&#13;&#10;  ELSE &quot;Affordable&quot;&#13;&#10;  END' />
      </column>
      <column caption='State MHS Fixed' datatype='real' name='[Calculation_0698807656820749]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [state] : AVG([Calculation_1820855439097863]) }' />
      </column>
      <column caption='State Rank Number' datatype='integer' name='[Calculation_0698807656878094]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(AVG([Calculation_1820855439097863]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='State Rank Direction' datatype='string' name='[Calculation_0698807656927247]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0698807656820749] &gt;= 0.045 THEN &quot; — Top Tier 🏆&quot;&#13;&#10;ELSEIF [Calculation_0698807656820749] &gt;= 0.030 THEN &quot; — Middle Tier&quot;&#13;&#10;ELSE &quot; — Needs Improvement&quot;&#13;&#10;END' />
      </column>
      <column caption='Bar - Selected State' datatype='real' default-format='*$#,##0,K' name='[Calculation_0698807659749392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [state] = [Parameters].[Parameter 2] THEN [home_value] ELSE NULL END)' />
      </column>
      <column caption='Bar - National Average' datatype='real' default-format='*$#,##0,K' name='[Calculation_0698807659794449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([home_value])' />
      </column>
      <column caption='Rate Row 4.0%' datatype='string' name='[Calculation_0698807662190610]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;4.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;4.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;4.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.004774))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.004774 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='State Rank Label' datatype='string' name='[Calculation_0698807663157267]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2]&#13;&#10;THEN &quot;#&quot; + STR(RANK_UNIQUE(AVG([Calculation_1820855439097863]), &apos;desc&apos;)) + &quot; of 51 states&quot;&#13;&#10;ELSE &quot;&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rate Row 4.5%' datatype='string' name='[Calculation_0698807668019220]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;4.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;4.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;4.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005066))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005066 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='Rate Row 5.0%' datatype='string' name='[Calculation_0698807668056085]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;5.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005368))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;5.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005368))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;5.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005368))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005368 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='Rate Row 5.5%' datatype='string' name='[Calculation_0698807668092950]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;5.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005679))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;5.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005679))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;5.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005679))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005679 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='Rate Row 6.0%' datatype='string' name='[Calculation_0698807668154391]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;6.0%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005996))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;6.0%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005996))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;6.0%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.005996))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.005996 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='Rate Row 6.5%' datatype='string' name='[Calculation_0698807668187160]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([median_household_income_lagged]) / 12 = 0 THEN &quot;N/A&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.40&#13;&#10;THEN &quot;6.5%::   (Crisis)       $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.006320))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSEIF AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) &gt;= 0.30&#13;&#10;THEN &quot;6.5%::   (Burdened)     $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.006320))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;ELSE &quot;6.5%::   (Affordable)   $&quot; + STR(INT(AVG([home_value]) * 0.8 * 0.006320))&#13;&#10;     + &quot; /mo          &quot;&#13;&#10;     + STR(ROUND(AVG([home_value]) * 0.8 * 0.006320 / (AVG([median_household_income_lagged]) / 12) * 100, 1))&#13;&#10;     + &quot;% burden&quot;&#13;&#10;END' />
      </column>
      <column caption='State Selected Flag' datatype='string' name='[Calculation_0698807670124571]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN &quot;Selected&quot; ELSE &quot;Other&quot; END' />
      </column>
      <column caption='State Rank Row Colour' datatype='string' name='[Calculation_0698807677292572]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN &quot;Show&quot; ELSE &quot;Hide&quot; END' />
      </column>
      <column caption='State Rank Sort' datatype='integer' name='[Calculation_0698807692714014]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [state] = [Parameters].[Parameter 2] THEN 0 ELSE 1 END' />
      </column>
      <column caption=' Is Selected State' datatype='boolean' name='[Calculation_0895342923030528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[state] = [Parameters].[Parameter 2]' />
      </column>
      <column caption='State Insight' datatype='string' name='[Calculation_0895342940409857]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Calculation_1820855438934020]) &gt;= 0.40 THEN&#13;&#10;  &quot;This state is in housing crisis. Over 40% of income goes to mortgage alone. Immediate supply-side intervention needed.&quot;&#13;&#10;ELSEIF AVG([Calculation_1820855438934020]) &gt;= 0.30 THEN&#13;&#10;  &quot;This state is cost-burdened. Residents spend 30-40% of income on housing. Zoning reform and affordable housing investment recommended.&quot;&#13;&#10;ELSEIF AVG([Calculation_1820855439097863]) &gt;= 0.045 THEN&#13;&#10;  &quot;This state shows a healthy housing market with manageable affordability. Strong opportunity for sustainable development.&quot;&#13;&#10;ELSE&#13;&#10;  &quot;This state shows moderate housing stress. Monitor affordability trends and consider targeted subsidy programmes.&quot;&#13;&#10;END' />
      </column>
      <column caption='State Insight Filter' datatype='boolean' name='[Calculation_0897269889589248]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[state] = [Parameters].[Parameter 2] OR [Parameters].[Parameter 2] = &quot;All States&quot;' />
      </column>
      <column caption='Reset Button' datatype='string' name='[Calculation_0897269910396929]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;↺  Reset to All States&quot;' />
      </column>
      <column caption='KPI YoY Value' datatype='real' default-format='p0.00%' name='[Calculation_1219424275316736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Calculation_2815916946829323]) - AVG([Calculation_2815916946882572]))&#13;&#10;/ ABS(AVG([Calculation_2815916946882572]))' />
      </column>
      <column caption='Home Value Comparison Label' datatype='string' name='[Calculation_1585288625455106]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;$&quot; + STR(INT(AVG([home_value]) / 1000)) + &quot;K&quot;' />
      </column>
      <column caption='Monthly Income' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438614528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[median_household_income_lagged] / 12' />
      </column>
      <column caption='Loan Amount' datatype='real' name='[Calculation_1820855438696449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[home_value] * 0.8' />
      </column>
      <column caption='Monthly Rate' datatype='real' name='[Calculation_1820855438766082]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([mortgage_rate] / 100) / 12' />
      </column>
      <column caption='Monthly Mortgage Payment' datatype='real' default-format='*$#,##0' name='[Calculation_1820855438835715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438696449]&#13;&#10;* ([Calculation_1820855438766082] * (1 + [Calculation_1820855438766082])^360)&#13;&#10;/ ((1 + [Calculation_1820855438766082])^360 - 1)' />
      </column>
      <column caption='Mortgage Burden Ratio' datatype='real' default-format='p0.0%' name='[Calculation_1820855438934020]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438835715] / [Calculation_1820855438614528]' />
      </column>
      <column caption='Affordability Ratio' datatype='real' default-format='n#,##0.000;-#,##0.000' name='[Calculation_1820855438987269]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[median_household_income_lagged] / [home_value]' />
      </column>
      <column caption='Economic Stability' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1820855439044614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - ([unemployment_rate] / 100)' />
      </column>
      <column caption='Investment Score' datatype='real' default-format='n#,##0.0000;-#,##0.0000' name='[Calculation_1820855439097863]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438987269]&#13;&#10;* (1 / [mortgage_rate])&#13;&#10;* [Calculation_1820855439044614]' />
      </column>
      <column caption='YoY Home Value Change' datatype='real' name='[Calculation_1820855439142920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(SUM([home_value])) - LOOKUP(ZN(SUM([home_value])), -12)) / ABS(LOOKUP(ZN(SUM([home_value])), -12))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Affordability Category' datatype='string' name='[Calculation_1820855439241225]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1820855438934020] &gt;= 0.40 THEN &quot;Crisis (&gt;40%)&quot;&#13;&#10;ELSEIF [Calculation_1820855438934020] &gt;= 0.30 THEN &quot;Cost-Burdened (30-40%)&quot;&#13;&#10;ELSEIF [Calculation_1820855438934020] &gt;= 0.20 THEN &quot;Stretched (20-30%)&quot;&#13;&#10;ELSE &quot;Affordable (&lt;20%)&quot;&#13;&#10;END' />
      </column>
      <column caption='Investment Category' datatype='string' name='[Calculation_1820855439319050]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1820855439097863] &gt;= 0.045 THEN &quot;High Opportunity&quot;&#13;&#10;ELSEIF [Calculation_1820855439097863] &gt;= 0.030 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;Low Opportunity&quot;&#13;&#10;END' />
      </column>
      <column caption='Home Value ($K)' datatype='real' default-format='*$#,##0.0&quot;K&quot;' name='[Calculation_1820855439364107]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[home_value] / 1000' />
      </column>
      <column caption='What-If Monthly Payment' datatype='real' name='[Calculation_1820855439699980]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([home_value] * 0.8)&#13;&#10;* (([Parameters].[Parameter 1]/100/12) * (1+([Parameters].[Parameter 1]/100/12))^360)&#13;&#10;/ ((1+([Parameters].[Parameter 1]/100/12))^360 - 1)' />
      </column>
      <column caption='What-If Mortgage Burden' datatype='real' name='[Calculation_1820855439757325]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855439699980] / [Calculation_1820855438614528]' />
      </column>
      <column caption='Monthly Savings from Rate Cut' datatype='real' default-format='*$#,##0' name='[Calculation_1820855439818766]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1820855438835715] - [Calculation_1820855439699980]' />
      </column>
      <column caption='YoY Category' datatype='string' name='[Calculation_1820855471538191]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1820855439142920] &gt;= 0 THEN &quot;Growing&quot;&#13;&#10;ELSE &quot;Falling&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Key Insight' datatype='string' name='[Calculation_2442356450684928]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN&#13;&#10;  IF AVG([Calculation_1820855438934020]) &gt;= 0.40 THEN&#13;&#10;    [Parameters].[Parameter 2] + &quot; is in HOUSING CRISIS. &quot; +&#13;&#10;    &quot;Monthly mortgage consumes &quot; + &#13;&#10;    STR(ROUND(AVG([Calculation_1820855438934020])*100,1)) + &#13;&#10;    &quot;% of median income — above the 40% HUD severe threshold.&quot;&#13;&#10;  ELSEIF AVG([Calculation_1820855438934020]) &gt;= 0.30 THEN&#13;&#10;    [Parameters].[Parameter 2] + &quot; is COST-BURDENED. &quot; +&#13;&#10;    STR(ROUND(AVG([Calculation_1820855438934020])*100,1)) +&#13;&#10;    &quot;% of income consumed by mortgage — above HUD&apos;s 30% threshold.&quot;&#13;&#10;  ELSEIF AVG([Calculation_1820855439097863]) &gt;= 0.045 THEN&#13;&#10;    [Parameters].[Parameter 2] + &quot; has a HEALTHY housing market. &quot; +&#13;&#10;    &quot;Investment Score &quot; + STR(ROUND(AVG([Calculation_1820855439097863]),4)) +&#13;&#10;    &quot; — affordable relative to income with stable employment.&quot;&#13;&#10;  ELSE&#13;&#10;    [Parameters].[Parameter 2] + &quot; shows MODERATE stress. &quot; +&#13;&#10;    &quot;Monitor affordability trends. Income-price ratio: &quot; +&#13;&#10;    STR(ROUND(AVG([Calculation_1820855438987269]),3))&#13;&#10;  END&#13;&#10;ELSE&#13;&#10;  &quot;Select a state on the map to see its insight.&quot;&#13;&#10;END' />
      </column>
      <column caption='Recommended Policy Actions' datatype='string' name='[Calculation_2442356451745793]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ATTR([state]) = [Parameters].[Parameter 2] THEN&#13;&#10;  IF AVG([Calculation_1820855438934020]) &gt;= 0.40 THEN&#13;&#10;    &quot;1. Emergency affordable housing investment&quot; + CHAR(10) +&#13;&#10;    &quot;2. Fast-track social housing zoning&quot; + CHAR(10) +&#13;&#10;    &quot;3. Lobby for federal rate intervention below 6%&quot; + CHAR(10) +&#13;&#10;    &quot;4. First-home buyer subsidy programme&quot;&#13;&#10;  ELSEIF AVG([Calculation_1820855438934020]) &gt;= 0.30 THEN&#13;&#10;    &quot;1. Zoning reform — increase housing supply&quot; + CHAR(10) +&#13;&#10;    &quot;2. Incentivise affordable unit development&quot; + CHAR(10) +&#13;&#10;    &quot;3. Monitor rent-to-own conversion rates&quot; + CHAR(10) +&#13;&#10;    &quot;4. Anti-speculation land tax review&quot;&#13;&#10;  ELSEIF AVG([Calculation_1820855439097863]) &gt;= 0.045 THEN&#13;&#10;    &quot;1. Invest in infrastructure to support growth&quot; + CHAR(10) +&#13;&#10;    &quot;2. Maintain current zoning flexibility&quot; + CHAR(10) +&#13;&#10;    &quot;3. Attract workforce housing development&quot; + CHAR(10) +&#13;&#10;    &quot;4. Monitor for investor demand pressure&quot;&#13;&#10;  ELSE&#13;&#10;    &quot;1. Conduct affordability impact assessment&quot; + CHAR(10) +&#13;&#10;    &quot;2. Review housing supply pipeline&quot; + CHAR(10) +&#13;&#10;    &quot;3. Consider targeted rental subsidy&quot; + CHAR(10) +&#13;&#10;    &quot;4. Track YoY price growth quarterly&quot;&#13;&#10;  END&#13;&#10;ELSE&#13;&#10;  &quot;Select a state on the map for policy recommendations.&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI YoY by State' datatype='real' default-format='p0.00%' name='[Calculation_2442356452065282]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END) = 0&#13;&#10;OR ISNULL(AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END))&#13;&#10;THEN NULL&#13;&#10;ELSE&#13;&#10;  (AVG(IF YEAR([date])=2026 AND MONTH([date])=2 THEN [home_value] END) -&#13;&#10;   AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END)) /&#13;&#10;  ABS(AVG(IF YEAR([date])=2025 AND MONTH([date])=2 THEN [home_value] END))&#13;&#10;END' />
      </column>
      <column caption='Burden Filter Combined' datatype='boolean' name='[Calculation_2442356459171843]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Top 20 Burden States] OR ([state] = [Parameters].[Parameter 2])' />
      </column>
      <column caption='Selected State Match' datatype='boolean' name='[Calculation_2442356460617732]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[state] = [Parameters].[Parameter 2]' />
      </column>
      <column caption='What if Filter Combined' datatype='boolean' name='[Calculation_2442356463087621]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Top 15 Payment States] OR ([state] = [Parameters].[Parameter 2])' />
      </column>
