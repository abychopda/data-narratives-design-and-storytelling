            <column caption='State' datatype='string' name='[state]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Calculation_0126236343406609]' derivation='User' name='[usr:Calculation_0126236343406609:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0126236343676946]' derivation='User' name='[usr:Calculation_0126236343676946:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0126236343910419]' derivation='User' name='[usr:Calculation_0126236343910419:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1219424275316736]' derivation='User' name='[usr:Calculation_1219424275316736:qk]' pivot='key' type='quantitative' />
