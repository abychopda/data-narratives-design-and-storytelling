          </filter>
          <filter class='quantitative' column='[federated.0fksw5k1j1adv319ck3id0f8r7xr].[none:date:qk]' included-values='in-range'>
            <min>#2024-01-31#</min>
            <max>#2026-02-28#</max>
          </filter>
          <filter class='categorical' column='[federated.0fksw5k1j1adv319ck3id0f8r7xr].[none:state:nk]' filter-group='6'>
